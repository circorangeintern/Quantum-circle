{
  "name": "speaksafe-backend",
  "version": "1.0.0",
  "description": "Anonymous reporting system for boarding schools - SpeakSafe MVP",
  "private": true,
  "main": "dist/server.js",
  "type": "commonjs",
  "jest": {
    "testEnvironment": "ts-node"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "dev:debug": "nodemon --inspect",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "clean": "rimraf dist coverage logs",
    "type-check": "tsc --noEmit",
    "render-build": "npm install --include=dev && npm run build"
  },
  "dependencies": {
    "@types/json2csv": "^5.0.7",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "http-errors": "^2.0.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nanoid": "^6.0.0",
    "pdfkit": "^0.19.1",
    "streamifier": "^0.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.1",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "unrs-resolver@1.12.2": true,
    "mongodb-memory-server@11.2.0": true,
    "vue-demi@0.14.10": true,
    "esbuild@0.28.1": true,
    "@scarf/scarf@1.4.0": true
  }
}
